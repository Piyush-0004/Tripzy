<% layout("/layouts/boilerplate")%> 

<div class="container mt-4">

  <!-- TITLE -->
  <h2 class="mb-3"><%= listing.title %></h2>

  <!-- TOP SECTION -->
  <div class="row">

    <!-- LEFT: IMAGE -->
    <div class="col-md-7">
      <img src="<%= listing.image.url %>" 
           class="img-fluid rounded shadow-sm show-img" 
           alt="listing_image">
    </div>

    <!-- RIGHT: DETAILS -->
    <div class="col-md-5">

      <div class="card p-3 shadow-sm border-0">

        <p class="mb-1 text-muted">
          Owned by <b><%= listing.owner.username %></b>
        </p>

        <p><%= listing.description %></p>

        <h4 class="fw-bold">
          ₹ <%= listing.price.toLocaleString("en-IN") %>
        </h4>

        <p class="text-muted">
          <%= listing.location %>, <%= listing.country %>
        </p>

        <!-- BOOK BUTTON -->
        <% if (currUser && !listing.owner._id.equals(currUser._id)) { %>
          <form method="GET" action="/bookings/<%= listing._id %>/pay">
            <button class="btn btn-danger w-100 mt-2">Book Now</button>
          </form>
        <% } else if (!currUser) { %>
          <a href="/login" class="btn btn-warning w-100 mt-2">Login to Book</a>
        <% } %>

      </div>

    </div>

  </div>

  <!-- EDIT & DELETE -->
  <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
    <div class="mt-3">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>

      <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="d-inline">
        <button class="btn btn-dark">Delete</button>
      </form>
    </div>
  <% } %>

  <hr>

  <!-- REVIEW FORM -->
  <% if(currUser) { %>
    <h4>Leave a review</h4>

    <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
      
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>

        <fieldset class="starability-slot">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5">5 stars</label>
        </fieldset>
      </div>

      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea name="review[comment]" id="comment" rows="4" class="form-control" required></textarea>
        <div class="invalid-feedback">Please add some comments</div>
      </div>

      <button class="btn btn-outline-dark">Submit</button>
    </form>

    <hr>
  <% } %>

  <!-- REVIEWS -->
  <% if(listing.reviews.length > 0) { %>
    <h4>All Reviews</h4>

    <div class="row">
      <% for(review of listing.reviews) { %>
        <div class="col-md-6 mb-3">
          <div class="card p-3 shadow-sm border-0 h-100">
            <h6>@<%= review.author.username %></h6>

            <p class="starability-result" data-rating="<%= review.rating %>"></p>

            <p><%= review.comment %></p>

            <form method="POST" action="/listings/<%=listing.id%>/reviews/<%=review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-dark">Delete</button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- MAP -->
  <div class="mt-4">
    <h4>Where you'll be</h4>
    <div id="map"></div>
  </div>

</div>

<script src="/js/map.js"></script>